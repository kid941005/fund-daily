# Fund Daily 环境变量配置
# 复制此文件为 .env: cp .env.example .env
# ⚠️ 仅需修改标有 ⚠️ 的变量

# ============== ⚠️ 必须设置 ==============

# PostgreSQL 密码（Docker 和应用共用）
POSTGRES_PASSWORD=change_me_strong_password

# JWT 签名密钥（至少32字符）
# 生成: python3 -c "import secrets; print(secrets.token_hex(32))"
FUND_DAILY_JWT_SECRET=change_me_jwt_secret_at_least_32_chars

# 应用加密密钥（至少32字符）
FUND_DAILY_SECRET_KEY=change_me_secret_key_at_least_32_chars

# 数据库密码（与 POSTGRES_PASSWORD 相同）
FUND_DAILY_DB_PASSWORD=change_me_strong_password

# ============== 可选配置（一般不需要修改） ==============

# PostgreSQL 配置
POSTGRES_USER=kid
POSTGRES_DB=fund_daily
FUND_DAILY_DB_HOST=postgres
FUND_DAILY_DB_PORT=5432
FUND_DAILY_DB_NAME=fund_daily
FUND_DAILY_DB_USER=kid

# Redis 配置
FUND_DAILY_REDIS_HOST=redis
FUND_DAILY_REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# 服务器配置
FUND_DAILY_SERVER_HOST=0.0.0.0
FUND_DAILY_SERVER_PORT=5000
FUND_DAILY_ENV=production

# CORS 配置（生产环境建议设置具体域名）
FUND_DAILY_CORS_ORIGINS=*

# 其他配置（一般不需要修改）
FUND_DAILY_REDIS_TTL=1800
FUND_DAILY_CACHE_DURATION=600
FUND_DAILY_LOG_LEVEL=INFO
