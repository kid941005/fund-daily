# Fund Daily Configuration

# Security Settings
# Secret key for session - generate with: python -c "import secrets; print(secrets.token_hex(32))"
FUND_DAILY_SECRET_KEY=your_secret_key_here
# Set to 'production' to enable secure cookies
FLASK_ENV=development
# Set to '0' to disable SSL verification (only for dev/internal networks)
FUND_DAILY_SSL_VERIFY=1

# Telegram Bot Settings (optional)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Default Fund Codes
FUND_CODES=000001,110022,161725

# Report Time (24-hour format)
REPORT_TIME=15:00
