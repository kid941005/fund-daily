# Fund Daily 环境变量配置
# 复制此文件为 .env: cp .env.example .env

# ============== ⚠️ 必须设置 ==============

# PostgreSQL 密码
POSTGRES_PASSWORD=change_me_password

# ============== 可选配置（一般不需要修改） ==============

# PostgreSQL 配置
POSTGRES_USER=kid
POSTGRES_DB=fund_daily
POSTGRES_PORT=5432

# Redis 配置
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PORT=6379

# 服务器配置
FUND_DAILY_SERVER_PORT=5000
