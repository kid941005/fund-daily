# 数据库配置
POSTGRES_USER=fund_daily_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=fund_daily

# 应用配置
FUND_DAILY_DB_TYPE=postgres
FUND_DAILY_DB_HOST=postgres
FUND_DAILY_DB_PORT=5432
FUND_DAILY_DB_NAME=fund_daily
FUND_DAILY_DB_USER=fund_daily_user
FUND_DAILY_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379

# JWT 安全配置
FUND_DAILY_JWT_SECRET=CHANGE_ME_VERY_STRONG_JWT_SECRET_KEY_AT_LEAST_32_CHARS
FUND_DAILY_JWT_EXPIRE_MINUTES=60
FUND_DAILY_JWT_REFRESH_DAYS=7

# 应用安全配置
FUND_DAILY_SECRET_KEY=CHANGE_ME_VERY_STRONG_SECRET_KEY_FOR_FLASK

# 缓存配置
FUND_DAILY_CACHE_DURATION=600

# 环境
FUND_DAILY_ENV=production