# ========================
# Fund Daily - 环境配置示例
# ========================
# 版本: 2.7.10
# 复制此文件为 .env 并修改实际值

# ============== 数据库 ==============
# 数据库密码
DB_PASSWORD=your-db-password-here
POSTGRES_PASSWORD=your-db-password-here
POSTGRES_USER=kid
POSTGRES_DB=fund_daily
POSTGRES_PORT=5432

# FastAPI JWT 签名密钥（使用 python3 -c "import secrets; print(secrets.token_hex(32))" 生成）
FUND_DAILY_SECRET_KEY=your-secret-key-here

# 数据库配置 (使用 PostgreSQL)
FUND_DAILY_DB_TYPE=postgres
FUND_DAILY_DB_HOST=postgres
FUND_DAILY_DB_PORT=5432
FUND_DAILY_DB_NAME=fund_daily
FUND_DAILY_DB_USER=kid
FUND_DAILY_DB_PASSWORD=your-db-password-here

# ============== Redis ==============
# Redis 配置 (Docker 环境)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=1800

# ============== 缓存 ==============
FUND_DAILY_CACHE_DURATION=1800

# ============== 安全 ==============
# SSL 验证
FUND_DAILY_SSL_VERIFY=1

# ============== 应用 ==============
# 基金代码 (可选)
FUND_CODES=

# 报告时间
REPORT_TIME=15:00

# ============== 告警 ==============
# 涨跌幅提醒
ALERT_THRESHOLD=3.0
ALERT_COOLDOWN=3600
CHECK_INTERVAL=300

# ============== 通知 (可选) ==============
# 钉钉通知
DINGTALK_WEBHOOK=

# Telegram通知
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 邮件通知
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_TO=
