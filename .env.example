# Fund Daily 环境变量配置文件
# 复制此文件为 .env 并填写实际值

# ============== 数据库配置 ==============
# 数据库类型 (postgres 或 sqlite)
FUND_DAILY_DB_TYPE=postgres

# PostgreSQL 连接配置
FUND_DAILY_DB_HOST=localhost
FUND_DAILY_DB_PORT=5432
FUND_DAILY_DB_NAME=fund_daily
FUND_DAILY_DB_USER=kid
FUND_DAILY_DB_PASSWORD=your_database_password_here

# ============== Redis 配置 ==============
FUND_DAILY_REDIS_HOST=localhost
FUND_DAILY_REDIS_PORT=6379
FUND_DAILY_REDIS_DB=0
FUND_DAILY_REDIS_PASSWORD=
FUND_DAILY_REDIS_TTL=1800

# ============== 应用配置 ==============
# 应用密钥 (用于会话加密)
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
FUND_DAILY_SECRET_KEY=your_secret_key_here_至少32个字符

# JWT 密钥 (用于API认证)
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
FUND_DAILY_JWT_SECRET=your_jwt_secret_key_here_至少32个字符

# 应用环境 (development, production)
FUND_DAILY_ENV=development

# 服务器配置
FUND_DAILY_SERVER_HOST=0.0.0.0
FUND_DAILY_SERVER_PORT=5000
FUND_DAILY_SERVER_DEBUG=false

# ============== 缓存配置 ==============
FUND_DAILY_CACHE_DURATION=600
FUND_DAILY_REQUEST_INTERVAL=0.5

# ============== 安全配置 ==============
# 是否使用安全cookie (生产环境应设为true)
FUND_DAILY_SECURE_COOKIES=false

# 是否验证SSL证书 (开发环境可设为false)
FUND_DAILY_SSL_VERIFY=true

# CORS 白名单 (逗号分隔，生产环境请务必配置)
# 示例: https://fund.example.com,https://admin.example.com
FUND_DAILY_CORS_ORIGINS=

# ============== 监控配置 ==============
# Prometheus 指标端口 (默认不启用)
FUND_DAILY_PROMETHEUS_METRICS_PORT=9090

# ============== 外部API配置 ==============
# 东方财富API基础URL (一般不需要修改)
FUND_DAILY_EASTMONEY_API_BASE=https://fund.eastmoney.com

# ============== 日志配置 ==============
FUND_DAILY_LOG_LEVEL=INFO
FUND_DAILY_LOG_FILE=/var/log/fund-daily/app.log

# ============== 调度器配置 ==============
# 调度器时区 (默认: 亚洲/上海)
FUND_DAILY_SCHEDULER_TIMEZONE=Asia/Shanghai

# 是否启用集群模式 (多实例部署时启用)
FUND_DAILY_SCHEDULER_CLUSTER_ENABLED=true

# 分布式锁TTL (秒)
FUND_DAILY_SCHEDULER_LOCK_TTL=300

# 调度器实例ID (集群模式下需要唯一)
FUND_DAILY_SCHEDULER_INSTANCE_ID=

# 调度器日志级别
FUND_DAILY_SCHEDULER_LOG_LEVEL=INFO

# ============== 可选功能 ==============
# 启用OCR功能 (需要安装easyocr，约2GB)
FUND_DAILY_ENABLE_OCR=false

# ============== 开发配置 ==============
# 开发环境可以启用调试功能
FUND_DAILY_DEBUG=false
