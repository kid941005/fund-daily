# ============== 数据库 ==============
POSTGRES_USER=admin
POSTGRES_PASSWORD=dev_password_123
POSTGRES_DB=fund_daily_dev

# 数据库配置
FUND_DAILY_DB_TYPE=postgres
FUND_DAILY_DB_HOST=localhost
FUND_DAILY_DB_PORT=5432
FUND_DAILY_DB_NAME=fund_daily_dev
FUND_DAILY_DB_USER=admin
FUND_DAILY_DB_PASSWORD=dev_password_123

# ============== Redis ==============
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============== 安全 ==============
# FastAPI JWT 签名密钥（开发环境）
FUND_DAILY_SECRET_KEY=dev-secret-key-change-in-production
FUND_DAILY_JWT_EXPIRE_MINUTES=60

# ============== 缓存 ==============
FUND_DAILY_CACHE_DURATION=600

# ============== 服务 ==============
FUND_DAILY_SERVER_PORT=5007
FUND_DAILY_ENV=development
FUND_DAILY_DEBUG=false

# ============== SSL ==============
FUND_DAILY_SSL_VERIFY=1
