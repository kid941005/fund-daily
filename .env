# 使用: docker-compose up -d

# ============== 数据库 ==============
# 数据库密码
DB_PASSWORD=941005
POSTGRES_PASSWORD=941005
POSTGRES_USER=kid
POSTGRES_DB=fund_daily
POSTGRES_PORT=5432

# Flask Secret Key (FastAPI JWT 签名密钥)
