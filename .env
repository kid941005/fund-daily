FUND_DAILY_DB_PORT=5432
FUND_DAILY_DB_NAME=fund_daily
FUND_DAILY_DB_USER=kid
FUND_DAILY_DB_PASSWORD=941005

# ============== Redis ==============
# Redis 配置 (Docker 环境)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=1800

# ============== 缓存 ==============
FUND_DAILY_CACHE_DURATION=1800

# ============== 服务 ==============
# 服务端口
FUND_DAILY_SERVER_HOST=0.0.0.0
FUND_DAILY_SERVER_PORT=5007

# ============== 安全 ==============
# SSL 验证
FUND_DAILY_SSL_VERIFY=1

# ============== 应用 ==============
# 基金代码 (可选)
FUND_CODES=

# 报告时间
REPORT_TIME=15:00

# ============== 告警 ==============
# 涨跌幅提醒
ALERT_THRESHOLD=3.0
ALERT_COOLDOWN=3600
CHECK_INTERVAL=300

# ============== 通知 (可选) ==============
# 钉钉通知
DINGTALK_WEBHOOK=

# Telegram通知
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 邮件通知
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_TO=
