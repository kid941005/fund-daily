# Docker Compose 开发环境覆盖配置
# 复制此文件为 docker-compose.override.yml 用于开发环境

version: '3.8'

services:
  # 开发环境后端配置
  backend:
    build:
      target: builder  # 使用构建阶段，包含开发工具
    environment:
      - FUND_DAILY_ENV=development
      - FUND_DAILY_SERVER_DEBUG=true
      - FLASK_DEBUG=true
      - FLASK_ENV=development
      - LOG_LEVEL=DEBUG
      - FUND_DAILY_SECURE_COOKIES=false
      - FUND_DAILY_SSL_VERIFY=false
    volumes:
      - ./src:/app/src:ro
      - ./web:/app/web:ro
      - ./db:/app/db:ro
      - ./scripts:/app/scripts:ro
      - ./config:/app/config:ro
      - ./tests:/app/tests:ro
    ports:
      - "5000:5000"
      - "5678:5678"  # 调试端口
    command: >
      sh -c "python -m debugpy --listen 0.0.0.0:5678 -m flask run --host=0.0.0.0 --port=5000 --reload"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

  # 开发环境前端配置（热重载）
  frontend-dev:
    build:
      context: ./web/vue3
      dockerfile: Dockerfile.dev
    container_name: fund-daily-frontend-dev
    ports:
      - "5173:5173"
    volumes:
      - ./web/vue3:/app:rw
      - /app/node_modules
    environment:
      - NODE_ENV=development
      - CHOKIDAR_USEPOLLING=true
    command: npm run dev
    networks:
      - fund-daily-network

  # 开发数据库（带管理界面）
  pgadmin:
    image: dpage/pgadmin4
    container_name: fund-daily-pgadmin
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@fund-daily.com
      PGADMIN_DEFAULT_PASSWORD: admin
    ports:
      - "5050:80"
    volumes:
      - pgadmin_data:/var/lib/pgadmin
    depends_on:
      - postgres
    networks:
      - fund-daily-network

  # Redis 管理界面
  redis-commander:
    image: rediscommander/redis-commander:latest
    container_name: fund-daily-redis-commander
    environment:
      - REDIS_HOSTS=local:redis:6379
      - HTTP_USER=admin
      - HTTP_PASSWORD=admin
    ports:
      - "8081:8081"
    depends_on:
      - redis
    networks:
      - fund-daily-network

  # 数据库导出工具
  db-exporter:
    image: postgres:15-alpine
    container_name: fund-daily-db-exporter
    depends_on:
      - postgres
    volumes:
      - ./data/backups:/backups
      - ./scripts/backup.sh:/backup.sh
    environment:
      - PGHOST=postgres
      - PGPORT=5432
      - PGDATABASE=fund_daily
      - PGUSER=kid
      - PGPASSWORD=941005
    command: >
      sh -c "while true; do sleep 3600; /backup.sh; done"
    networks:
      - fund-daily-network

volumes:
  pgadmin_data: